# Server Configuration
PORT=8000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# MongoDB Configuration
MONGODB_URI=your_mongoDB_URI
DB_NAME=careers-nitkkr

# JWT Configuration
ACCESS_TOKEN_SECRET=your-super-secret-jwt-key-change-this-in-production
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_SECRET=your-super-secret-refresh-key-change-this-in-production
REFRESH_TOKEN_EXPIRY=7d

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# Email Configuration
# ─── Email / SendGrid ─────────────────────────────────
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_FROM="NIT Kurukshetra Careers <your-gmail@gmail.com>"

# ─── Razorpay ─────────────────────────────────────────
# Get keys from: https://dashboard.razorpay.com/app/keys
# Use "Test Mode" keys during development (prefix: rzp_test_)
# Use "Live Mode" keys in production (prefix: rzp_live_)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# REMOVED — No longer used after Stripe → Razorpay migration:
# STRIPE_SECRET_KEY
# STRIPE_WEBHOOK_SECRET

# ─── File Upload ──────────────────────────────────────
MAX_FILE_SIZE=10485760   # 10MB in bytes
